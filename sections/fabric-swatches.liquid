{% schema %}
{
  "name": "Color Cards Section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Choose Your Color"
    }
  ],
  "blocks": [
    {
      "type": "color_card",
      "name": "Color Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Title",
          "default": "Black"
        },
        {
          "type": "text",
          "id": "card_rating",
          "label": "Rating",
          "default": "4.8 ★ (6)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Color Cards Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="container my-5">
  <h2 class="text-center">{{ section.settings.section_heading }}</h2>
  <div class="fabric-imgs">
    {% for block in section.blocks %}
      <div class="color-box">
        {% if block.settings.card_image != blank %}
          <img src="{{ block.settings.card_image | image_url: width: 400 }}" alt="{{ block.settings.card_title }}" class="color-img">
        {% endif %}
        <div class="overlay">
          <p>{{ block.settings.card_title }}</p>
          <span>{{ block.settings.card_rating }}</span>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
h2 {
  font-size: 2rem;
  margin-bottom: 2rem;
}

/* ✅ GRID LAYOUT */
.fabric-imgs {
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* max 4 per row */
  gap: 20px;
}

.color-box {
  border-radius: 8px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  color: #d4e2d4;
  overflow: hidden;
  flex-direction: column;
  text-align: left;
  background: #d4e2d4;
}

div#shopify-section-template--26145283965266__fabric_swatches_T8VbyV {
    margin-bottom: 5rem;
    margin-top: -9rem;
}

/* ✅ Image Styling */
.color-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease; /* Smooth transition for zoom */
}

/* ✅ Image Hover Zoom Effect */
.color-box:hover .color-img {
  transform: scale(1.1); /* Zoom image on hover */
}

/* ✅ Overlay Text Styling */
.color-box .overlay {
  text-align: left;
  padding: 20px 15px;
  padding-top: 15px;
}

.color-box p {
  font-size: 1.2rem;
  font-weight: bold;
}

.color-box span {
  font-size: 1rem;
  display: block;
  margin-top: 5px;
}

.overlay p, .overlay span {
  color: black;
}

/* 📱 Responsive */
@media (max-width: 992px) {
  .fabric-imgs {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .fabric-imgs {
    grid-template-columns: repeat(2, 1fr);
  }
  .color-box {
    height: 400px;
  }

.color-box .overlay {
    text-align: left;
    padding: 15px 15px !important;
    margin-bottom: 3rem;
}

div#shopify-section-template--26145283965266__fabric_swatches_T8VbyV {
    margin-bottom: 5rem;
    margin-top: -6rem;
}
}

@media (max-width: 576px) {
  .fabric-imgs {
    grid-template-columns: repeat(1, 1fr);
  }
  .color-box {
    height: 300px;
  }

 .color-box .overlay {
    text-align: left;
    padding: 15px 15px !important;
    margin-bottom: 6rem;
}

div#shopify-section-template--26145283965266__fabric_swatches_T8VbyV {
    margin-bottom: 5rem;
    margin-top: -6rem;
}
}
</style>
