{% doc %}
  @prompt
    texte qui défile de droite à gauche
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrolling-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-scrolling-text__wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-scrolling-text__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding: 0 {{ block.settings.spacing }}px;
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.font_weight }};
  }

  .ai-scrolling-text__separator-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    margin: 0 {{ block.settings.spacing }}px;
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-scrolling-text__wrapper-{{ ai_gen_id }}:hover {
    animation-play-state: {{ block.settings.pause_on_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-scrolling-text__item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<scrolling-text-{{ ai_gen_id }}
  class="ai-scrolling-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-scrolling-text__wrapper-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      <div class="ai-scrolling-text__item-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
      {% if block.settings.show_separator %}
        <span class="ai-scrolling-text__separator-{{ ai_gen_id }}"></span>
      {% endif %}
      <div class="ai-scrolling-text__item-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
      {% if block.settings.show_separator %}
        <span class="ai-scrolling-text__separator-{{ ai_gen_id }}"></span>
      {% endif %}
      <div class="ai-scrolling-text__item-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
      {% if block.settings.show_separator %}
        <span class="ai-scrolling-text__separator-{{ ai_gen_id }}"></span>
      {% endif %}
      <div class="ai-scrolling-text__item-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
      {% if block.settings.show_separator %}
        <span class="ai-scrolling-text__separator-{{ ai_gen_id }}"></span>
      {% endif %}
    {% endfor %}
  </div>
</scrolling-text-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollingText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustScrollSpeed();
      }

      adjustScrollSpeed() {
        const wrapper = this.querySelector('.ai-scrolling-text__wrapper-{{ ai_gen_id }}');
        if (wrapper) {
          const wrapperWidth = wrapper.scrollWidth / 2;
          const speed = {{ block.settings.scroll_speed }};
          wrapper.style.animationDuration = speed + 's';
        }
      }
    }

    customElements.define('scrolling-text-{{ ai_gen_id }}', ScrollingText{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Texte défilant",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texte",
      "default": "Livraison gratuite à partir de 50€ • Retours sous 30 jours • Service client 7j/7"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur ordinateur",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Taille de police",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Épaisseur de police",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Moyen"
        },
        {
          "value": "600",
          "label": "Semi-gras"
        },
        {
          "value": "700",
          "label": "Gras"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#D4637A"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Espacement vertical",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Séparateur"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Afficher le séparateur",
      "default": true
    },
    {
      "type": "range",
      "id": "separator_size",
      "label": "Taille du séparateur",
      "min": 4,
      "max": 12,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Couleur du séparateur",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Espacement entre éléments",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Défilement"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Vitesse de défilement",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "select",
      "id": "pause_on_hover",
      "label": "Pause au survol",
      "options": [
        {
          "value": "running",
          "label": "Non"
        },
        {
          "value": "paused",
          "label": "Oui"
        }
      ],
      "default": "paused"
    }
  ],
  "presets": [
    {
      "name": "Texte défilant"
    }
  ]
}
{% endschema %}
